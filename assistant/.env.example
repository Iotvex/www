# iotvex-assistant — copy to .env and fill in your values
# cp .env.example .env

# ── Server ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8777
DEBUG=false

# ── Iotvex home control ───────────────────────────────────────────────────
# Production www (Vercel). For a self-hosted box use e.g. http://95.31.206.51
IOTVEX_WWW_URL=https://iotvex.vercel.app
# IOTVEX_AGENT_URL=http://95.31.206.51:8765
IOTVEX_TOKEN=your_service_token_here

# ── TTS ───────────────────────────────────────────────────────────────────
TTS_VOICE_RU=en-US-EmmaMultilingualNeural
TTS_VOICE_EN=en-US-AriaNeural
TTS_VOICE_EN=en-US-JennyNeural
TTS_INCLUDE_AUDIO=true
TTS_FORMAT=mp3

# ── STT ───────────────────────────────────────────────────────────────────
# stub | whisper | vosk
STT_BACKEND=stub
WHISPER_MODEL=base

# ── LLM (optional, requires ollama running locally) ───────────────────────
LLM_ENABLED=false
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma2:2b
LLM_CONFIDENCE_THRESHOLD=0.55
