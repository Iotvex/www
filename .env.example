# Iotvex WWW
#
# Primary runtime config (hot-reload): config/runtime.json
# Secrets: config/runtime.secrets.json
# Env below is bootstrap / docker interpolation fallback.

# WWW: local | local_published | cloud
# (legacy aliases: lan→local, published→local_published)
IOTVEX_WWW_MODE=local_published
IOTVEX_MDNS_NAME=iotvex.local
IOTVEX_CUSTOM_DOMAIN=
IOTVEX_HTTP_PORT=3100
IOTVEX_HTTPS_PORT=8443
IOTVEX_CLOUD_WWW_URL=

# DB: local | cloud_public | cloud_private
# (legacy alias: remote→cloud_private)
IOTVEX_DB_MODE=local

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_BROWSER_URL=/supabase

# Optional presets for cloud DB targets (also editable in Settings → Services)
IOTVEX_CLOUD_PUBLIC_SUPABASE_URL=
IOTVEX_CLOUD_PUBLIC_ANON_KEY=
IOTVEX_CLOUD_PUBLIC_SERVICE_ROLE_KEY=
IOTVEX_CLOUD_PRIVATE_SUPABASE_URL=
IOTVEX_CLOUD_PRIVATE_ANON_KEY=
IOTVEX_CLOUD_PRIVATE_SERVICE_ROLE_KEY=

IOTVEX_AGENT_URL=http://127.0.0.1:7421
REDIS_URL=redis://127.0.0.1:6379
CRON_SECRET=
IOTVEX_TZ=Europe/Moscow
TZ=Europe/Moscow
SEED_EMAIL=admin@iotvex.local
SEED_PASSWORD=
